# 막차세이브 환경 변수 템플릿
# 실제 값은 .env.local 에 넣고 절대 커밋하지 않습니다.

# ─────────────────────────────────────────
# 카카오맵 (공공 프론트엔드 SDK)
# https://developers.kakao.com 앱 생성 → 앱 키 → JavaScript 키
# ─────────────────────────────────────────
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ─────────────────────────────────────────
# 카카오 REST API (주소/키워드 검색, 서버 전용)
# 위 Kakao Developers 앱의 REST API 키
# ─────────────────────────────────────────
KAKAO_REST_KEY=

# ─────────────────────────────────────────
# ODsay 대중교통 경로 API
# https://lab.odsay.com/ 가입 → 애플리케이션 등록 → API Key
# ─────────────────────────────────────────
ODSAY_KEY=

# ─────────────────────────────────────────
# 공공데이터포털 서비스 키
# https://www.data.go.kr
#
# 포털 계정은 1개지만 API 마다 활용신청이 필요합니다.
# 아래 두 키는 값이 동일할 수도, 다를 수도 있습니다. 같은 값이면
# 같은 문자열을 두 변수에 넣어도 됩니다.
#
# TAGO_SERVICE_KEY — 국토교통부 TAGO 초정밀버스 실시간 위치 정보
#   https://www.data.go.kr/data/15098534/openapi.do
# PUBLIC_BIKE_SERVICE_KEY — 행정안전부 한국지역정보개발원
#   전국 공영자전거 실시간 정보 (B551982/pbdo_v2)
#   https://www.data.go.kr/data/15126639/openapi.do
# ─────────────────────────────────────────
TAGO_SERVICE_KEY=
PUBLIC_BIKE_SERVICE_KEY=
